# ═══════════════════════════════════════════════════════════
# ONE ERA — Environment Variables
# Copy file này thành .env.local để test local
# Trên Vercel: Settings → Environment Variables → thêm từng dòng
# ═══════════════════════════════════════════════════════════

# Google Sheets (Apps Script Web App URL)
# Lấy từ: Apps Script → Deploy → Web App → URL
GOOGLE_SHEETS_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Resend API Key — dùng để gửi email thông báo lead
# Lấy từ: resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email nhận lead (có thể nhiều email, cách nhau dấu phẩy)
RECEIVER_EMAIL=oneerabykinera@gmail.com
